---
import PageLayout from '../../layouts/PageLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import type { Props as SeoProps } from '../../components/Seo.astro';
import { SITE_URL, DEFAULT_OG_IMAGE } from '../../data/site';
import { tools, toolUrl, CATEGORY_LABELS, type ToolCategory } from '../../data/tools';

const CATEGORY_ORDER: ToolCategory[] = ['developer', 'text', 'media', 'calculator', 'fun'];
const grouped = CATEGORY_ORDER.map((cat) => ({
  cat,
  label: CATEGORY_LABELS[cat],
  items: tools.filter((t) => t.category === cat),
})).filter((g) => g.items.length > 0);

const seo: SeoProps = {
  title: 'All Tools | Online Tools — Free Web Utilities',
  description:
    'Explore free online tools for developers and creatives: converters, text utilities, JSON tools, and more. Fast, easy-to-use, and browser-based resources.',
  canonical: `${SITE_URL}/tools/`,
  keywords: 'online tools, web utilities, converters, calculators, image tools, text tools',
  hreflang: [
    { hreflang: 'en', href: `${SITE_URL}/tools/` },
    { hreflang: 'es', href: `${SITE_URL}/es/tools/` },
    { hreflang: 'fr', href: `${SITE_URL}/fr/tools/` },
    { hreflang: 'x-default', href: `${SITE_URL}/tools/` },
  ],
  og: {
    type: 'website',
    url: `${SITE_URL}/tools/`,
    title: 'All Tools | Online Tools',
    description: 'Browse every free, browser-based tool: converters, JSON utilities, text tools, calculators and more.',
    image: DEFAULT_OG_IMAGE,
    siteName: 'Online Tools',
    locale: 'en_US',
  },
  twitter: {
    card: 'summary_large_image',
    url: `${SITE_URL}/tools/`,
    title: 'All Tools | Online Tools',
    description: 'Browse every free, browser-based tool.',
    image: DEFAULT_OG_IMAGE,
  },
  jsonLd: [
    {
      '@context': 'https://schema.org',
      '@type': 'CollectionPage',
      name: 'Online Tools Directory',
      description: 'A directory of free, browser-based online tools and utilities.',
      url: `${SITE_URL}/tools/`,
      mainEntity: {
        '@type': 'ItemList',
        itemListElement: tools.map((t, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: t.name,
          url: toolUrl(t.slug),
        })),
      },
    },
  ],
};
let cardIndex = 0;
---
<PageLayout seo={seo} lang="en" current="tools" adsEnabled={true}>
  <header class="listing-head">
    <h1>All Tools</h1>
    <p>Every tool is free, runs entirely in your browser, and never uploads your data.</p>
  </header>

  <section aria-label="Search" class="search">
    <label for="tool-search-input" class="sr-only">Search for tools</label>
    <input type="search" id="tool-search-input" placeholder="Search tools by name or description..." autocomplete="off" />
  </section>
  <p id="no-results-message" class="no-results" style="display:none" aria-live="polite">No tools found matching your search.</p>

  {grouped.map((g) => (
    <section class="cat" aria-labelledby={`cat-${g.cat}`}>
      <h2 id={`cat-${g.cat}`} class="cat-title">{g.label}</h2>
      <div class="tool-grid">
        {g.items.map((t) => {
          cardIndex++;
          return (
            <ToolCard
              href={toolUrl(t.slug).replace(SITE_URL, '')}
              name={t.name}
              description={t.description}
              headingId={`tool-heading-${cardIndex}`}
            />
          );
        })}
      </div>
    </section>
  ))}

  <script is:inline>
    (function () {
      var input = document.getElementById('tool-search-input');
      var cards = Array.prototype.slice.call(document.querySelectorAll('.tool-card'));
      var noResults = document.getElementById('no-results-message');
      if (!input || !cards.length) return;
      input.addEventListener('input', function () {
        var q = input.value.toLowerCase().trim();
        var found = 0;
        cards.forEach(function (card) {
          var a = card.querySelector('h3 a');
          var p = card.querySelector('p');
          var title = ((a && a.textContent) || '').toLowerCase();
          var desc = ((p && p.textContent) || '').toLowerCase();
          var visible = !q || title.indexOf(q) !== -1 || desc.indexOf(q) !== -1;
          card.style.display = visible ? '' : 'none';
          if (visible) found++;
        });
        document.querySelectorAll('.cat').forEach(function (sec) {
          var any = Array.prototype.slice.call(sec.querySelectorAll('.tool-card')).some(function (c) { return c.style.display !== 'none'; });
          sec.style.display = any ? '' : 'none';
        });
        if (noResults) noResults.style.display = found === 0 && q ? 'block' : 'none';
      });
    })();
  </script>
</PageLayout>

<style>
  .listing-head { text-align: center; padding: 16px 0 8px; }
  .listing-head h1 { font-size: 2.25rem; margin: 0 0 8px; color: var(--md-sys-color-on-surface); }
  .listing-head p { margin: 0 auto; max-width: 38rem; color: var(--md-sys-color-on-surface-variant); }
  .search { max-width: 42rem; margin: 24px auto 8px; }
  #tool-search-input {
    width: 100%; padding: 14px 20px; font-size: 1rem;
    border: 1px solid var(--md-sys-color-outline); border-radius: 999px;
    background: var(--md-sys-color-surface-container-lowest); color: var(--md-sys-color-on-surface);
  }
  #tool-search-input:focus { outline: 2px solid var(--md-sys-color-primary); border-color: transparent; }
  .no-results { text-align: center; color: var(--md-sys-color-on-surface-variant); padding: 24px 0; }
  .cat { margin: 32px 0; }
  .cat-title {
    font-size: 1.375rem; margin: 0 0 16px; padding-bottom: 8px;
    color: var(--md-sys-color-on-surface);
    border-bottom: 2px solid var(--md-sys-color-primary-container);
  }
  .tool-grid { display: grid; grid-template-columns: 1fr; gap: 24px; }
  @media (min-width: 640px) { .tool-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .tool-grid { grid-template-columns: repeat(3, 1fr); } }
</style>
