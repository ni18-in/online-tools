---
import ToolLayout from '../../../../layouts/ToolLayout.astro';
import type { Props as SeoProps } from '../../../../components/Seo.astro';
import { SITE_URL, DEFAULT_OG_IMAGE } from '../../../../data/site';
import body from '../../../../components/legacy/es/tool-jwt-debugger/body.html?raw';
import css from '../../../../components/legacy/es/tool-jwt-debugger/styles.css?raw';
import js from '../../../../components/legacy/es/tool-jwt-debugger/script.js?raw';

const seo: SeoProps = {
  title: 'Depurador y Visor de JWT - Decodificar JSON Web Tokens Online',
  description: 'Herramienta online fácil de usar para decodificar, inspeccionar y verificar JSON Web Tokens (JWT) del lado del cliente. Visualiza encabezado, carga útil y firma.',
  keywords: 'depurador de jwt, decodificador de jwt, visor de jwt, decodificar jwt, verificar jwt, firma de jwt, reclamaciones de token',
  canonical: `${SITE_URL}/es/tools/jwt-debugger/`,
  hreflang: [
    { hreflang: 'en', href: `${SITE_URL}/tools/jwt-debugger/` },
    { hreflang: 'es', href: `${SITE_URL}/es/tools/jwt-debugger/` },
    { hreflang: 'fr', href: `${SITE_URL}/fr/tools/jwt-debugger/` },
    { hreflang: 'x-default', href: `${SITE_URL}/tools/jwt-debugger/` },
  ],
  og: {
    type: 'website',
    url: `${SITE_URL}/es/tools/jwt-debugger/`,
    title: 'Depurador y Visor de JWT - Decodificar JSON Web Tokens Online',
    description: 'Decodifica, inspecciona y verifica JSON Web Tokens (JWT) de forma local y segura.',
    image: DEFAULT_OG_IMAGE,
    locale: 'es_ES'
  },
  twitter: {
    card: 'summary_large_image',
    url: `${SITE_URL}/es/tools/jwt-debugger/`,
    title: 'Depurador y Visor de JWT - Decodificar JSON Web Tokens Online',
    description: 'Decodifica, inspecciona y verifica JSON Web Tokens (JWT) de forma local y segura.',
    image: DEFAULT_OG_IMAGE
  },
  jsonLd: [{
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Depurador y Visor de JWT',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'All',
    url: `${SITE_URL}/es/tools/jwt-debugger/`,
    description: 'Herramienta online fácil de usar para decodificar, inspeccionar y verificar JSON Web Tokens (JWT) del lado del cliente.',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' }
  }],
};
const headRaw = "<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">";
---
<ToolLayout seo={seo} lang="es" altLinks={{ en: `${SITE_URL}/tools/jwt-debugger/`, fr: `${SITE_URL}/fr/tools/jwt-debugger/` }} headRaw={headRaw} adMinHeight={120}>
  <div class="tool-island legacy-tw" id="tool-jwt-debugger" set:html={body} />
</ToolLayout>
<style is:global set:html={css}></style>
<script is:inline set:html={js}></script>
