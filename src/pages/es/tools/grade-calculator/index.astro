---
import ToolLayout from '../../../../layouts/ToolLayout.astro';
import type { Props as SeoProps } from '../../../../components/Seo.astro';
import { SITE_URL, DEFAULT_OG_IMAGE } from '../../../../data/site';
import body from '../../../../components/legacy/es/tool-grade-calculator/body.html?raw';
import css from '../../../../components/legacy/es/tool-grade-calculator/styles.css?raw';
import js from '../../../../components/legacy/es/tool-grade-calculator/script.js?raw';

const seo: SeoProps = {
  title: 'Calculadora de Calificaciones Universal - Ponderada y Fácil',
  description: 'La calculadora de promedio ponderado más rápida y sencilla. Define categorías, agrega tareas y obtén tu calificación de curso en tiempo real.',
  keywords: 'calculadora de calificaciones, gpa escolar, calcular promedio ponderado',
  canonical: 'https://online-tools.ni18.in/es/tools/grade-calculator/',
  hreflang: [
    { hreflang: 'en', href: 'https://online-tools.ni18.in/tools/grade-calculator/' },
    { hreflang: 'es', href: 'https://online-tools.ni18.in/es/tools/grade-calculator/' },
    { hreflang: 'fr', href: 'https://online-tools.ni18.in/fr/tools/grade-calculator/' },
    { hreflang: 'x-default', href: 'https://online-tools.ni18.in/tools/grade-calculator/' },
  ],
  og: {
    type: 'website',
    url: 'https://online-tools.ni18.in/es/tools/grade-calculator/',
    title: 'Calculadora de Calificaciones Universal - Ponderada y Fácil',
    description: 'La calculadora de promedio ponderado más rápida y sencilla. Define categorías, agrega tareas y obtén tu calificación de curso en tiempo real.',
    image: DEFAULT_OG_IMAGE,
    locale: 'es_ES'
  },
  twitter: {
    card: 'summary_large_image',
    url: 'https://online-tools.ni18.in/es/tools/grade-calculator/',
    title: 'Calculadora de Calificaciones Universal - Ponderada y Fácil',
    description: 'La calculadora de promedio ponderado más rápida y sencilla. Define categorías, agrega tareas y obtén tu calificación de curso en tiempo real.',
    image: DEFAULT_OG_IMAGE
  },
  jsonLd: [{
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Calculadora de Calificaciones Universal - Ponderada y Fácil',
    applicationCategory: 'EducationalApplication',
    operatingSystem: 'All',
    url: 'https://online-tools.ni18.in/es/tools/grade-calculator/',
    description: 'La calculadora de promedio ponderado más rápida y sencilla. Define categorías, agrega tareas y obtén tu calificación de curso en tiempo real.',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' }
  }],
};

---
<ToolLayout seo={seo} lang="es" altLinks={{ en: 'https://online-tools.ni18.in/tools/grade-calculator/', fr: 'https://online-tools.ni18.in/fr/tools/grade-calculator/' }} adMinHeight={120}>
  <div class="tool-island legacy-tw" id="tool-grade-calculator" set:html={body} />
</ToolLayout>
<style is:global set:html={css}></style>
<script is:inline set:html={js}></script>
