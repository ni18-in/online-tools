    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' }
  }],
};

---
<ToolLayout seo={seo} lang="es" altLinks={{ en: 'https://online-tools.ni18.in/tools/guess-the-logo/', fr: 'https://online-tools.ni18.in/fr/tools/guess-the-logo/' }} adMinHeight={120}>
  <div class="tool-island" id="tool-guess-the-logo" set:html={body} />
</ToolLayout>
<style is:global set:html={css}></style>
<script is:inline set:html={js}></script>
