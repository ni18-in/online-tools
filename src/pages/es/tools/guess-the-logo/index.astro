  hreflang: [
    { hreflang: 'en', href: 'https://online-tools.ni18.in/tools/guess-the-logo/' },
    { hreflang: 'es', href: 'https://online-tools.ni18.in/es/tools/guess-the-logo/' },
    { hreflang: 'fr', href: 'https://online-tools.ni18.in/fr/tools/guess-the-logo/' },
    { hreflang: 'x-default', href: 'https://online-tools.ni18.in/tools/guess-the-logo/' },
  ],
  og: {
    type: 'website',
    url: 'https://online-tools.ni18.in/es/tools/guess-the-logo/',
    title: 'Adivina el Logo - Juego de Quiz de Marcas',
    description: '¡Pon a prueba tus conocimientos sobre marcas comerciales con Adivina el Logo! Un divertido y adictivo juego de preguntas con múltiples modos de juego.',
    image: DEFAULT_OG_IMAGE,
    locale: 'es_ES'
  },
  twitter: {
