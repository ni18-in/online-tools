---
import PageLayout from '../../../layouts/PageLayout.astro';
import ToolCard from '../../../components/ToolCard.astro';
import type { Props as SeoProps } from '../../../components/Seo.astro';
import { SITE_URL, SITE_NAME, DEFAULT_OG_IMAGE } from '../../../data/site';
import { tools, toolUrl, TOOL_TRANSLATIONS, type ToolCategory } from '../../../data/tools';

const CATEGORY_ORDER: ToolCategory[] = ['developer', 'text', 'media', 'calculator', 'fun'];

const CATEGORY_LABELS_ES: Record<ToolCategory, string> = {
  developer: 'Desarrollo',
  text: 'Texto y Contenido',
  media: 'Imágenes y Medios',
  calculator: 'Calculadoras',
  fun: 'Juegos y Diversión',
};

// Filter to only include tools that have a Spanish translation (t.i18n.es)
const esTools = tools.filter((t) => t.i18n?.es);

const grouped = CATEGORY_ORDER.map((cat) => ({
  cat,
  label: CATEGORY_LABELS_ES[cat],
  items: esTools.filter((t) => t.category === cat),
})).filter((g) => g.items.length > 0);

const seo: SeoProps = {
  title: 'Todas las Herramientas | NI18 Herramientas Online',
  description: 'Explora el catálogo completo de herramientas web gratuitas de NI18, incluyendo conversores, utilidades de texto y herramientas para desarrolladores.',
  canonical: `${SITE_URL}/es/tools/`,
  keywords: 'herramientas online, utilidades web, conversores, calculadoras, desarrolladores',
  hreflang: [
    { hreflang: 'en', href: `${SITE_URL}/tools/` },
    { hreflang: 'es', href: `${SITE_URL}/es/tools/` },
    { hreflang: 'fr', href: `${SITE_URL}/fr/tools/` },
    { hreflang: 'x-default', href: `${SITE_URL}/tools/` },
  ],
  og: {
    type: 'website',
    url: `${SITE_URL}/es/tools/`,
    title: 'Todas las Herramientas – NI18',
    description: 'Catálogo de herramientas web gratuitas en tu navegador.',
    image: DEFAULT_OG_IMAGE,
    siteName: SITE_NAME,
    locale: 'es_ES',
  },
  twitter: {
    card: 'summary_large_image',
    url: `${SITE_URL}/es/tools/`,
    title: 'Todas las Herramientas – NI18',
    description: 'Catálogo de herramientas web gratuitas en tu navegador.',
    image: DEFAULT_OG_IMAGE,
  },
  jsonLd: [
    {
      '@context': 'https://schema.org',
      '@type': 'CollectionPage',
      name: 'Directorio de Herramientas Online',
      description: 'Un directorio completo de herramientas y utilidades web gratuitas para usar directamente en el navegador.',
      url: `${SITE_URL}/es/tools/`,
      mainEntity: {
        '@type': 'ItemList',
        itemListElement: esTools.map((t, i) => {
          const esSlug = t.i18n?.es || t.slug;
          const trans = TOOL_TRANSLATIONS[t.slug]?.es;
          return {
            '@type': t.schemaType,
            position: i + 1,
            name: trans?.name || t.name,
            url: `${SITE_URL}/es/tools/${esSlug}/`,
          };
        }),
      },
    },
  ],
};
let cardIndex = 0;
---
<PageLayout seo={seo} lang="es" current="tools" adsEnabled={true}>
  <header class="listing-head">
    <h1>Todas las Herramientas</h1>
    <p>Cada herramienta es gratuita, se ejecuta completamente en tu navegador y nunca carga tus datos.</p>
  </header>

  <section aria-label="Buscar" class="search">
    <label for="tool-search-input" class="sr-only">Buscar herramientas</label>
    <input type="search" id="tool-search-input" placeholder="Buscar herramientas por nombre o descripción..." autocomplete="off" />
  </section>
  <p id="no-results-message" class="no-results" style="display:none" aria-live="polite">
    No se encontraron herramientas que coincidan con tu búsqueda.
  </p>

  {grouped.map((g) => (
    <section class="cat" aria-labelledby={`cat-${g.cat}`}>
      <h2 id={`cat-${g.cat}`} class="cat-title">{g.label}</h2>
      <div class="tool-grid">
        {g.items.map((t) => {
          cardIndex++;
          const esSlug = t.i18n?.es || t.slug;
          const trans = TOOL_TRANSLATIONS[t.slug]?.es;
          return (
            <ToolCard
              href={`/es/tools/${esSlug}/`}
              name={trans?.name || t.name}
              description={trans?.description || t.description}
              headingId={`tool-heading-${cardIndex}`}
              cta="Iniciar"
            />
          );
        })}
      </div>
    </section>
  ))}

  <script is:inline>
    (function () {
      var input = document.getElementById('tool-search-input');
      var cards = Array.prototype.slice.call(document.querySelectorAll('.tool-card'));
      var noResults = document.getElementById('no-results-message');
      if (!input || !cards.length) return;
      input.addEventListener('input', function () {
        var q = input.value.toLowerCase().trim();
        var found = 0;
        cards.forEach(function (card) {
          var a = card.querySelector('h3 a');
          var p = card.querySelector('p');
          var title = ((a && a.textContent) || '').toLowerCase();
          var desc = ((p && p.textContent) || '').toLowerCase();
          var visible = !q || title.indexOf(q) !== -1 || desc.indexOf(q) !== -1;
          card.style.display = visible ? '' : 'none';
          if (visible) found++;
        });
        document.querySelectorAll('.cat').forEach(function (sec) {
          var any = Array.prototype.slice.call(sec.querySelectorAll('.tool-card')).some(function (c) { return c.style.display !== 'none'; });
          sec.style.display = any ? '' : 'none';
        });
        if (noResults) noResults.style.display = found === 0 && q ? 'block' : 'none';
      });
    })();
  </script>
</PageLayout>

<style>
  .listing-head { text-align: center; padding: 16px 0 8px; }
  .listing-head h1 { font-size: 2.25rem; margin: 0 0 8px; color: var(--md-sys-color-on-surface); }
  .listing-head p { margin: 0 auto; max-width: 38rem; color: var(--md-sys-color-on-surface-variant); }
  .search { max-width: 42rem; margin: 24px auto 8px; }
  #tool-search-input {
    width: 100%; padding: 14px 20px; font-size: 1rem;
    border: 1px solid var(--md-sys-color-outline); border-radius: 999px;
    background: var(--md-sys-color-surface-container-lowest); color: var(--md-sys-color-on-surface);
  }
  #tool-search-input:focus { outline: 2px solid var(--md-sys-color-primary); border-color: transparent; }
  .no-results { text-align: center; color: var(--md-sys-color-on-surface-variant); padding: 24px 0; }
  .cat { margin: 32px 0; }
  .cat-title {
    font-size: 1.375rem; margin: 0 0 16px; padding-bottom: 8px;
    color: var(--md-sys-color-on-surface);
    border-bottom: 2px solid var(--md-sys-color-primary-container);
  }
  .tool-grid { display: grid; grid-template-columns: 1fr; gap: 24px; }
  @media (min-width: 640px) { .tool-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .tool-grid { grid-template-columns: repeat(3, 1fr); } }
</style>
