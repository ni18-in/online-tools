---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import type { Props as SeoProps } from '../../../components/Seo.astro';
import { SITE_URL, SITE_NAME, DEFAULT_OG_IMAGE } from '../../../data/site';
import body from '../../../components/legacy/es/tools/body.html?raw';
import css from '../../../components/legacy/es/tools/styles.css?raw';
import '../../../styles/tw-preflight-scoped.css';

const seo: SeoProps = {
  title: 'Todas las Herramientas – NI18 Herramientas Online',
  description: 'Explora el catálogo completo de herramientas web gratuitas de NI18, incluyendo conversores, utilidades de texto y herramientas para desarrolladores.',
  keywords: 'herramientas online, utilidades web, conversores, calculadoras',
  canonical: `${SITE_URL}/es/tools/`,
  hreflang: [
    { hreflang: 'en', href: `${SITE_URL}/tools/` },
    { hreflang: 'es', href: `${SITE_URL}/es/tools/` },
    { hreflang: 'fr', href: `${SITE_URL}/fr/tools/` },
    { hreflang: 'x-default', href: `${SITE_URL}/tools/` },
  ],
  og: { type: 'website', url: `${SITE_URL}/es/tools/`, title: 'Todas las Herramientas – NI18', description: 'Catálogo de herramientas web gratuitas.', image: DEFAULT_OG_IMAGE, siteName: SITE_NAME, locale: 'es_ES' },
  twitter: { card: 'summary_large_image', url: `${SITE_URL}/es/tools/`, title: 'Todas las Herramientas – NI18', description: 'Catálogo de herramientas web gratuitas.', image: DEFAULT_OG_IMAGE },
};
---
<BaseLayout seo={seo} lang="es" current="tools" altLinks={{ en: `${SITE_URL}/tools/`, fr: `${SITE_URL}/fr/tools/` }}>
  <div class="page-island legacy-tw" set:html={body} />
</BaseLayout>
<style is:global set:html={css}></style>
<style>:global(.page-island.legacy-tw){background:#f8fafc;color:#0f172a;}</style>
