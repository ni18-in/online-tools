---
import BlogLayout from '../../../layouts/BlogLayout.astro';
import { blogPosts, blogSeo } from '../../../data/blogs';

const bodies = import.meta.glob('../../../components/legacy/es/blog-*/body.html', { query: '?raw', import: 'default', eager: true });
const styles = import.meta.glob('../../../components/legacy/es/blog-*/styles.css', { query: '?raw', import: 'default', eager: true });

const pick = (map: Record<string, unknown>, slug: string, file: string): string => {
  const key = Object.keys(map).find((p) => p.endsWith(`/blog-${slug}/${file}`));
  return key ? (map[key] as string) : '';
};

export function getStaticPaths() {
  const esPosts = blogPosts.filter((p) => p.i18n?.es);
  return esPosts.map((post) => ({
    params: { slug: post.i18n!.es!.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const seo = blogSeo(post, 'es');
const body = pick(bodies, post.slug, 'body.html');
const css = pick(styles, post.slug, 'styles.css');
---
<BlogLayout seo={seo} lang="es">
  <article class="blog-island legacy-tw" id={`blog-${post.slug}`} set:html={body} />
</BlogLayout>

<style is:global set:html={css}></style>
