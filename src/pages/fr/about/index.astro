---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import type { Props as SeoProps } from '../../../components/Seo.astro';
import { SITE_URL, SITE_NAME, DEFAULT_OG_IMAGE } from '../../../data/site';
import body from '../../../components/legacy/fr/about/body.html?raw';
import css from '../../../components/legacy/fr/about/styles.css?raw';
import '../../../styles/tw-preflight-scoped.css';

const seo: SeoProps = {
  title: 'À propos de nous – Outils en Ligne',
  description: 'Découvrez la mission de NI18 Outils en Ligne : fournir des utilitaires web gratuits, simples et utiles directement dans votre navigateur.',
  keywords: 'à propos, outils en ligne, utilitaires web gratuits, mission, ni18',
  canonical: `${SITE_URL}/fr/about/`,
  hreflang: [
    { hreflang: 'en', href: `${SITE_URL}/about/` },
    { hreflang: 'es', href: `${SITE_URL}/es/about/` },
    { hreflang: 'fr', href: `${SITE_URL}/fr/about/` },
    { hreflang: 'x-default', href: `${SITE_URL}/about/` },
  ],
  og: { type: 'website', url: `${SITE_URL}/fr/about/`, title: 'À propos – NI18', description: 'La mission de NI18 Outils en Ligne.', image: DEFAULT_OG_IMAGE, siteName: SITE_NAME, locale: 'fr_FR' },
  twitter: { card: 'summary_large_image', url: `${SITE_URL}/fr/about/`, title: 'À propos – NI18', description: 'La mission de NI18 Outils en Ligne.', image: DEFAULT_OG_IMAGE },
};
---
<BaseLayout seo={seo} lang="fr" current="about" altLinks={{ en: `${SITE_URL}/about/`, es: `${SITE_URL}/es/about/` }}>
  <div class="page-island legacy-tw" set:html={body} />
</BaseLayout>
<style is:global set:html={css}></style>
<style>:global(.page-island.legacy-tw){background:#f8fafc;color:#0f172a;}</style>
