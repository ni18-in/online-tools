<script is:inline>
(function() {
  function $(id) { return document.getElementById(id); }
  function $$(sel, ctx) { return (ctx || document).querySelectorAll(sel); }
  function show(el) { if (el) el.classList.remove('hidden'); }
  function hide(el) { if (el) el.classList.add('hidden'); }

  function imageHash(dataUrl) {
    var h = 0;
    var sample = dataUrl.substring(dataUrl.length - 2000);
    for (var i = 0; i < sample.length; i++) {
      h = ((h << 5) - h) + sample.charCodeAt(i);
      h |= 0;
    }
    return Math.abs(h);
  }

  $$('.beauty-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      var target = this.getAttribute('data-target');
      $$('.beauty-tab').forEach(function(t) { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      this.classList.add('active');
      this.setAttribute('aria-selected', 'true');
      $$('.beauty-section').forEach(function(s) { s.classList.add('hidden'); });
      var el = $(target);
      if (el) { show(el); el.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
    });
  });

  function handleFile(inputId, previewId, onFile) {
    var input = $(inputId);
    if (!input) return;

    function processFile(file) {
      var preview = $(previewId);
      if (file && file.type.startsWith('image/')) {
        var reader = new FileReader();
        reader.onload = function(e) {
          var dataUrl = e.target.result;
          if (preview) { preview.src = dataUrl; show(preview); }
          onFile(dataUrl);
        };
        reader.readAsDataURL(file);
      } else if (file) {
        alert('Veuillez télécharger un fichier image valide (JPG, PNG, GIF).');
      }
    }

    input.addEventListener('change', function() {
      if (this.files && this.files[0]) processFile(this.files[0]);
    });

    var area = input.closest('.upload-area');
    if (area) {
      area.addEventListener('click', function() { input.click(); });
      area.addEventListener('dragenter', function(e) { e.preventDefault(); e.stopPropagation(); area.classList.add('dragover'); });
      area.addEventListener('dragover', function(e) { e.preventDefault(); e.stopPropagation(); area.classList.add('dragover'); });
      area.addEventListener('dragleave', function(e) { e.preventDefault(); e.stopPropagation(); area.classList.remove('dragover'); });
      area.addEventListener('drop', function(e) {
        e.preventDefault(); e.stopPropagation();
        area.classList.remove('dragover');
        var files = e.dataTransfer && e.dataTransfer.files;
        if (files && files.length) processFile(files[0]);
      });
    }
  }

  function runLoader(loaderId, textId, prefix, duration, onDone) {
    var loader = $(loaderId);
    var text = $(textId);
    show(loader);
    if (text) text.textContent = prefix + ' 0%';
    var start = Date.now();
    var iv = setInterval(function() {
      var pct = Math.min(100, Math.floor(((Date.now() - start) / duration) * 100));
      if (text) text.textContent = prefix + ' ' + pct + '%';
      if (pct >= 100) clearInterval(iv);
    }, 80);
    setTimeout(function() {
      clearInterval(iv);
      if (text) text.textContent = prefix + ' 100%';
      hide(loader);
      onDone();
    }, duration);
  }

  function animateNumber(el, from, to, duration) {
    if (!el) return;
    var start = Date.now();
    var iv = setInterval(function() {
      var pct = Math.min(1, (Date.now() - start) / duration);
      var ease = 1 - Math.pow(1 - pct, 3);
      el.textContent = Math.round(from + (to - from) * ease);
      if (pct >= 1) clearInterval(iv);
    }, 30);
  }

  function animateBar(barId, valId, value) {
    var bar = $(barId);
    if (bar) { bar.style.width = '0%'; setTimeout(function() { bar.style.width = value + '%'; }, 100); }
    animateNumber($(valId), 0, value, 1000);
  }

  handleFile('scanner-upload', 'scanner-preview', function(dataUrl) {
    hide($('scanner-results'));
    var hash = imageHash(dataUrl);
    runLoader('scanner-loader', 'scanner-loader-text', 'Scan', 2200, function() {
      var overall = (hash % 31) + 70;
      var eyes = ((hash >> 3) % 26) + 72;
      var lips = ((hash >> 6) % 28) + 68;
      var nose = ((hash >> 9) % 26) + 70;
      var sym  = ((hash >> 12) % 21) + 75;

      animateNumber($('scanner-score'), 0, overall, 1000);

      var ring = $('scanner-ring');
      if (ring) {
        var circ = 2 * Math.PI * 52;
        ring.style.strokeDasharray = circ;
        ring.style.strokeDashoffset = circ;
        setTimeout(function() { ring.style.strokeDashoffset = circ - (circ * overall / 100); }, 50);
      }

      animateBar('scanner-eyes-bar', 'scanner-eyes', eyes);
      animateBar('scanner-lips-bar', 'scanner-lips', lips);
      animateBar('scanner-nose-bar', 'scanner-nose', nose);
      animateBar('scanner-sym-bar', 'scanner-sym', sym);

      show($('scanner-results'));
    });
  });

  var celebs = [
    { name: 'Aurore Étoile', emoji: '✨', trait: 'Charisme rayonnant et présence magnétique' },
    { name: 'Maximilien Flamme', emoji: '🔥', trait: 'Confiance audacieuse et leadership naturel' },
    { name: 'Luna Forêt', emoji: '🌙', trait: 'Élégance mystérieuse et force silencieuse' },
    { name: 'Phénix Rivera', emoji: '🌟', trait: 'Énergie vibrante et ambition imparable' },
    { name: 'Séréna Givre', emoji: '❄️', trait: 'Sang-froid et grâce sophistiquée' },
    { name: 'Orion Chevalier', emoji: '⚡', trait: 'Intellect aiguisé et détermination intrépide' },
    { name: 'Ivy Luxe', emoji: '💎', trait: 'Beauté intemporelle et goût raffiné' },
    { name: 'Atlas Tempête', emoji: '🌊', trait: 'Présence puissante et esprit aventurier' },
    { name: 'Céleste Lune', emoji: '🦋', trait: 'Chaleur douce et vision créative' },
    { name: 'Rex Doré', emoji: '👑', trait: 'Leader né avec un cœur en or' },
  ];

  handleFile('lookalike-upload', 'lookalike-preview', function(dataUrl) {
    hide($('lookalike-results'));
    var hash = imageHash(dataUrl);
    runLoader('lookalike-loader', 'lookalike-loader-text', 'Recherche', 2800, function() {
      var celeb = celebs[hash % celebs.length];
      var conf = ((hash >> 4) % 26) + 72;

      $('celeb-avatar').textContent = celeb.emoji;
      $('celeb-name').textContent = celeb.name;
      $('celeb-trait').textContent = '« ' + celeb.trait + ' »';

      var confBar = $('celeb-conf-bar');
      if (confBar) { confBar.style.width = '0%'; setTimeout(function() { confBar.style.width = conf + '%'; }, 100); }
      animateNumber($('celeb-confidence'), 0, conf, 800);
      setTimeout(function() { $('celeb-confidence').textContent = conf + '%'; }, 850);

      show($('lookalike-results'));
    });
  });

  var insights = {
    eyes: [
      "Vos yeux suggèrent un observateur perspicace — quelqu'un qui remarque les petits détails que d'autres manquent. Une âme créative avec un monde intérieur vif.",
      "Des yeux profonds et expressifs qui indiquent une profondeur émotionnelle et une forte intuition. Vous connectez facilement avec les autres à un niveau significatif.",
      "Des yeux brillants et clairs qui reflètent une énergie abondante et de la curiosité. Vous êtes du genre à illuminer chaque pièce dans laquelle vous entrez.",
      "La forme de vos yeux suggère l'équilibre et la sensibilité artistique — peut-être un amour pour l'esthétique et l'harmonie visuelle.",
      "Des yeux bien écartés qui indiquent une perspective ouverte et large, et une tolérance naturelle envers les nouvelles idées et points de vue divers."
    ],
    lips: [
      "Des lèvres pleines qui signalent souvent la générosité et la chaleur — vous êtes probablement quelqu'un vers qui les autres se tournent pour le réconfort et le soutien.",
      "Un arc de Cupidon défini qui suggère de fortes compétences en communication et une éloquence naturelle. Vous savez faire compter vos mots.",
      "Des lèvres équilibrées et symétriques qui reflètent la stabilité émotionnelle et l'équité. Vous valorisez l'harmonie dans les relations.",
      "Un sourire naturellement retroussé qui transmet l'optimisme et l'accessibilité. Les gens se sentent instantanément à l'aise autour de vous.",
      "La forme de vos lèvres suggère une nature passionnée — quelqu'un qui poursuit ses intérêts avec dévouement et cœur."
    ],
    nose: [
      "Un pont nasal droit souvent lié à la logique et à l'organisation — vous abordez probablement les défis de manière méthodique.",
      "Un nez proéminent qui suggère des qualités de leadership et de l'ambition. Vous n'avez pas peur de prendre les choses en main et de prendre des décisions.",
      "Un nez plus petit et raffiné qui suggère la sensibilité et l'attention aux détails — vous appréciez les bonnes choses de la vie.",
      "Un bout de nez arrondi associé à l'amabilité et la sociabilité. Vous êtes naturellement accessible et chaleureux(se).",
      "Un nez légèrement retroussé qui suggère l'optimisme et l'espièglerie — vous gardez les choses légères et apportez de la joie à ceux qui vous entourent."
    ]
  };

  handleFile('analysis-upload', 'analysis-preview', function(dataUrl) {
    hide($('analysis-results'));
    var hash = imageHash(dataUrl);
    runLoader('analysis-loader', 'analysis-loader-text', 'Analyse', 2000, function() {
      $('analysis-eyes').textContent = insights.eyes[(hash + 1) % insights.eyes.length];
      $('analysis-lips').textContent = insights.lips[(hash >> 5) % insights.lips.length];
      $('analysis-nose').textContent = insights.nose[(hash >> 10) % insights.nose.length];
      show($('analysis-results'));
    });
  });

  var sdData = { d1: null, d2: null };

  function checkShowdown() {
    if (!sdData.d1 || !sdData.d2) return;
    hide($('showdown-results'));
    var h1 = imageHash(sdData.d1);
    var h2 = imageHash(sdData.d2);
    runLoader('showdown-loader', 'showdown-loader-text', 'Comparaison', 3000, function() {
      var s1 = ((h1 + 50) % 31) + 68;
      var s2 = ((h2 + 60) % 31) + 68;

      animateNumber($('sd-score1'), 0, s1, 1000);
      animateNumber($('sd-score2'), 0, s2, 1000);

      var badge = $('showdown-winner');
      var wText = $('winner-text');

      setTimeout(function() {
        badge.className = 'winner-badge';
        if (s1 > s2) { badge.classList.add('win1'); wText.textContent = 'Image 1 Gagne ! 🏆'; }
        else if (s2 > s1) { badge.classList.add('win2'); wText.textContent = 'Image 2 Gagne ! 🏆'; }
        else { badge.classList.add('tie'); wText.textContent = 'Égalité ! 🤝'; }
        show(badge);
      }, 600);

      show($('showdown-results'));
    });
  }

  handleFile('showdown-upload1', 'showdown-preview1', function(d) { sdData.d1 = d; checkShowdown(); });
  handleFile('showdown-upload2', 'showdown-preview2', function(d) { sdData.d2 = d; checkShowdown(); });

})();
</script>
