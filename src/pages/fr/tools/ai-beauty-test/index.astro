---
import ToolLayout from '../../../../layouts/ToolLayout.astro';
import type { Props as SeoProps } from '../../../../components/Seo.astro';
import { SITE_URL, DEFAULT_OG_IMAGE } from '../../../../data/site';

const seo: SeoProps = {
  title: 'Test de Beauté IA - Score de Visage Gratuit & Sosie de Célébrité',
  description: 'Obtenez un score de beauté IA gratuit basé sur les traits du visage, trouvez votre sosie de célébrité et comparez des photos avec le Test de Beauté IA.',
  keywords: 'test de beauté ia, score de visage, analyse de beauté, sosie de célébrité',
  canonical: `${SITE_URL}/fr/tools/ai-beauty-test/`,
  robots: 'noindex, follow',
  hreflang: [
    { hreflang: 'en', href: `${SITE_URL}/tools/ai-beauty-test/` },
    { hreflang: 'es', href: `${SITE_URL}/es/tools/ai-beauty-test/` },
    { hreflang: 'fr', href: `${SITE_URL}/fr/tools/ai-beauty-test/` },
    { hreflang: 'x-default', href: `${SITE_URL}/tools/ai-beauty-test/` },
  ],
  og: { type: 'website', url: `${SITE_URL}/fr/tools/ai-beauty-test/`, title: 'Test de Beauté IA', description: 'Score de beauté IA gratuit.', image: DEFAULT_OG_IMAGE, locale: 'fr_FR' },
  twitter: { card: 'summary_large_image', url: `${SITE_URL}/fr/tools/ai-beauty-test/`, title: 'Test de Beauté IA', description: 'Score de beauté IA gratuit.', image: DEFAULT_OG_IMAGE },
};
const headRaw = `
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
`;
---
<ToolLayout seo={seo} lang="fr" headRaw={headRaw} altLinks={{ en: `${SITE_URL}/tools/ai-beauty-test/`, es: `${SITE_URL}/es/tools/ai-beauty-test/` }}>
  <div class="tool-island" id="tool-ai-beauty-test">

    <nav class="beauty-nav" aria-label="Fonctions du Test de Beauté">
      <button class="beauty-tab active" data-target="scanner" aria-selected="true">
        <i class="fas fa-wand-magic-sparkles"></i><span>Scanner</span>
      </button>
      <button class="beauty-tab" data-target="lookalike" aria-selected="false">
        <i class="fas fa-star"></i><span>Sosie</span>
      </button>
      <button class="beauty-tab" data-target="analysis" aria-selected="false">
        <i class="fas fa-magnifying-glass"></i><span>Analyse</span>
      </button>
      <button class="beauty-tab" data-target="showdown" aria-selected="false">
        <i class="fas fa-trophy"></i><span>Duel</span>
      </button>
      <button class="beauty-tab" data-target="how-to-use" aria-selected="false">
        <i class="fas fa-circle-question"></i><span>Mode d'emploi</span>
      </button>
    </nav>

    <!-- 1. SCANNER -->
    <section id="scanner" class="beauty-section">
      <div class="section-header">
        <div class="section-icon"><i class="fas fa-wand-magic-sparkles"></i></div>
        <div>
          <h2>Scan & Score du Visage</h2>
          <p>Téléchargez une photo et obtenez un score de beauté amusant basé sur les traits du visage comme les yeux, les lèvres, le nez et la symétrie.</p>
        </div>
      </div>

      <div class="upload-area" id="scanner-drop">
        <input type="file" id="scanner-upload" accept="image/*" class="file-input" />
        <label for="scanner-upload" class="upload-label">
          <div class="upload-icon"><i class="fas fa-cloud-arrow-up"></i></div>
          <span class="upload-text">Glissez votre photo ici ou <strong>cliquez pour télécharger</strong></span>
          <span class="upload-hint">JPG, PNG, GIF — toute photo claire de visage</span>
        </label>
        <img id="scanner-preview" class="preview-img hidden" alt="Aperçu du visage pour le scan" />
      </div>

      <div id="scanner-loader" class="loader hidden">
        <div class="loader-ring"></div>
        <p class="loader-label" id="scanner-loader-text">Scan 0%</p>
      </div>

      <div id="scanner-results" class="results hidden">
        <h3><i class="fas fa-chart-simple"></i> Votre Score de Beauté</h3>
        <div class="score-hero">
          <svg class="score-ring" viewBox="0 0 120 120" aria-hidden="true">
            <defs>
              <linearGradient id="scoreGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#6366f1"/>
                <stop offset="100%" stop-color="#a855f7"/>
              </linearGradient>
            </defs>
            <circle cx="60" cy="60" r="52" class="ring-bg"/>
            <circle cx="60" cy="60" r="52" class="ring-fill" id="scanner-ring" stroke-dasharray="326.73" stroke-dashoffset="326.73"/>
          </svg>
          <div class="score-number" id="scanner-score">0</div>
          <div class="score-label">/ 100</div>
        </div>
        <div class="score-details">
          <div class="detail-item">
            <i class="fas fa-eye"></i>
            <span class="detail-label">Yeux</span>
            <div class="detail-bar"><div class="detail-fill" id="scanner-eyes-bar"></div></div>
            <span class="detail-val" id="scanner-eyes">0</span>
          </div>
          <div class="detail-item">
            <i class="fas fa-face-kiss"></i>
            <span class="detail-label">Lèvres</span>
            <div class="detail-bar"><div class="detail-fill" id="scanner-lips-bar"></div></div>
            <span class="detail-val" id="scanner-lips">0</span>
          </div>
          <div class="detail-item">
            <i class="fas fa-head-side"></i>
            <span class="detail-label">Nez</span>
            <div class="detail-bar"><div class="detail-fill" id="scanner-nose-bar"></div></div>
            <span class="detail-val" id="scanner-nose">0</span>
          </div>
          <div class="detail-item">
            <i class="fas fa-arrows-left-right"></i>
            <span class="detail-label">Symétrie</span>
            <div class="detail-bar"><div class="detail-fill" id="scanner-sym-bar"></div></div>
            <span class="detail-val" id="scanner-sym">0</span>
          </div>
        </div>
        <p class="disclaimer">* Ceci est uniquement pour le divertissement — les scores sont simulés, pas de vraie IA.</p>
      </div>
    </section>

    <!-- 2. SOSIE -->
    <section id="lookalike" class="beauty-section hidden">
      <div class="section-header">
        <div class="section-icon purple"><i class="fas fa-star"></i></div>
        <div>
          <h2>Sosie de Célébrité</h2>
          <p>Découvrez à quel personnage célèbre fictif vous ressemblez ! Téléchargez une photo pour un match amusant.</p>
        </div>
      </div>

      <div class="upload-area" id="lookalike-drop">
        <input type="file" id="lookalike-upload" accept="image/*" class="file-input" />
        <label for="lookalike-upload" class="upload-label">
          <div class="upload-icon purple"><i class="fas fa-cloud-arrow-up"></i></div>
          <span class="upload-text">Glissez votre photo ici ou <strong>cliquez pour télécharger</strong></span>
          <span class="upload-hint">Une photo claire de face fonctionne le mieux</span>
        </label>
        <img id="lookalike-preview" class="preview-img hidden" alt="Aperçu du visage pour le sosie" />
      </div>

      <div id="lookalike-loader" class="loader hidden">
        <div class="loader-ring purple"></div>
        <p class="loader-label" id="lookalike-loader-text">Recherche 0%</p>
      </div>

      <div id="lookalike-results" class="results hidden">
        <h3><i class="fas fa-award"></i> Votre Correspondance</h3>
        <div class="celeb-card">
          <div class="celeb-avatar" id="celeb-avatar">🌟</div>
          <div class="celeb-info">
            <p class="celeb-name" id="celeb-name">—</p>
            <p class="celeb-trait" id="celeb-trait">—</p>
            <div class="confidence-bar-wrap">
              <span class="confidence-label">Confiance</span>
              <div class="confidence-bar"><div class="confidence-fill" id="celeb-conf-bar"></div></div>
              <span class="confidence-val" id="celeb-confidence">0%</span>
            </div>
          </div>
        </div>
        <p class="disclaimer">* Les célébrités sont fictives — c'est juste pour s'amuser !</p>
      </div>
    </section>

    <!-- 3. ANALYSE -->
    <section id="analysis" class="beauty-section hidden">
      <div class="section-header">
        <div class="section-icon blue"><i class="fas fa-magnifying-glass"></i></div>
        <div>
          <h2>Analyse des Traits du Visage</h2>
          <p>Obtenez des interprétations de personnalité amusantes basées sur les traits du visage comme les yeux, les lèvres et la forme du nez.</p>
        </div>
      </div>

      <div class="upload-area" id="analysis-drop">
        <input type="file" id="analysis-upload" accept="image/*" class="file-input" />
        <label for="analysis-upload" class="upload-label">
          <div class="upload-icon blue"><i class="fas fa-cloud-arrow-up"></i></div>
          <span class="upload-text">Glissez votre photo ici ou <strong>cliquez pour télécharger</strong></span>
          <span class="upload-hint">Meilleurs résultats avec une photo claire du visage</span>
        </label>
        <img id="analysis-preview" class="preview-img hidden" alt="Aperçu du visage pour l'analyse" />
      </div>

      <div id="analysis-loader" class="loader hidden">
        <div class="loader-ring blue"></div>
        <p class="loader-label" id="analysis-loader-text">Analyse 0%</p>
      </div>

      <div id="analysis-results" class="results hidden">
        <h3><i class="fas fa-magnifying-glass-chart"></i> Interprétations</h3>
        <div class="insight-cards">
          <div class="insight-card eyes-card">
            <div class="insight-icon"><i class="fas fa-eye"></i></div>
            <h4>Yeux</h4>
            <p id="analysis-eyes">Téléchargez une image pour voir l'analyse.</p>
          </div>
          <div class="insight-card lips-card">
            <div class="insight-icon"><i class="fas fa-face-smile"></i></div>
            <h4>Lèvres</h4>
            <p id="analysis-lips">Téléchargez une image pour voir l'analyse.</p>
          </div>
          <div class="insight-card nose-card">
            <div class="insight-icon"><i class="fas fa-wind"></i></div>
            <h4>Nez</h4>
            <p id="analysis-nose">Téléchargez une image pour voir l'analyse.</p>
          </div>
        </div>
        <p class="disclaimer">* Les interprétations sont uniquement pour le divertissement, basées sur des concepts de lecture faciale traditionnelle.</p>
      </div>
    </section>

    <!-- 4. DUEL -->
    <section id="showdown" class="beauty-section hidden">
      <div class="section-header">
        <div class="section-icon gold"><i class="fas fa-trophy"></i></div>
        <div>
          <h2>Duel de Beauté</h2>
          <p>Téléchargez deux photos et comparez leurs scores de beauté. Qui remporte la couronne ?</p>
        </div>
      </div>

      <div class="showdown-uploads">
        <div class="upload-area compact" id="showdown-drop1">
          <input type="file" id="showdown-upload1" accept="image/*" class="file-input" />
          <label for="showdown-upload1" class="upload-label">
            <div class="upload-icon gold"><i class="fas fa-cloud-arrow-up"></i></div>
            <span class="upload-text"><strong>Image 1</strong></span>
          </label>
          <img id="showdown-preview1" class="preview-img hidden" alt="Image 1 du duel" />
        </div>
        <div class="vs-badge">VS</div>
        <div class="upload-area compact" id="showdown-drop2">
          <input type="file" id="showdown-upload2" accept="image/*" class="file-input" />
          <label for="showdown-upload2" class="upload-label">
            <div class="upload-icon gold"><i class="fas fa-cloud-arrow-up"></i></div>
            <span class="upload-text"><strong>Image 2</strong></span>
          </label>
          <img id="showdown-preview2" class="preview-img hidden" alt="Image 2 du duel" />
        </div>
      </div>

      <div id="showdown-loader" class="loader hidden">
        <div class="loader-ring gold"></div>
        <p class="loader-label" id="showdown-loader-text">Comparaison 0%</p>
      </div>

      <div id="showdown-results" class="results hidden">
        <h3><i class="fas fa-scale-balanced"></i> Résultats du Duel</h3>
        <div class="showdown-scores">
          <div class="sd-score-card">
            <span class="sd-label">Image 1</span>
            <span class="sd-score" id="sd-score1">0</span>
          </div>
          <div class="sd-vs">vs</div>
          <div class="sd-score-card">
            <span class="sd-label">Image 2</span>
            <span class="sd-score" id="sd-score2">0</span>
          </div>
        </div>
        <div id="showdown-winner" class="winner-badge hidden">
          <i class="fas fa-crown"></i>
          <span id="winner-text">—</span>
        </div>
        <p class="disclaimer">* Les scores sont simulés — c'est uniquement pour le divertissement !</p>
      </div>
    </section>

    <!-- 5. MODE D'EMPLOI -->
    <section id="how-to-use" class="beauty-section hidden">
      <div class="section-header">
        <div class="section-icon teal"><i class="fas fa-circle-question"></i></div>
        <div>
          <h2>Mode d'emploi</h2>
          <p>Le Test de Beauté IA est simple et amusant — voici comment chaque fonction marche.</p>
        </div>
      </div>
      <div class="how-to-list">
        <div class="how-step"><span class="step-num">1</span><div><strong>Choisissez une Fonction</strong> — Sélectionnez Scanner, Sosie, Analyse ou Duel avec les onglets ci-dessus.</div></div>
        <div class="how-step"><span class="step-num">2</span><div><strong>Téléchargez une Photo</strong> — Cliquez ou glissez-déposez une photo claire de visage. Pour le Duel, téléchargez deux photos.</div></div>
        <div class="how-step"><span class="step-num">3</span><div><strong>Attendez l'Analyse</strong> — Une animation de chargement amusante se joue pendant que l'outil « analyse » votre photo.</div></div>
        <div class="how-step"><span class="step-num">4</span><div><strong>Consultez vos Résultats</strong> — Visualisez les scores animés, les correspondances de célébrités, les analyses de personnalité ou les résultats du duel.</div></div>
        <div class="how-step"><span class="step-num">5</span><div><strong>Réessayez !</strong> — Téléchargez différentes photos, essayez différentes fonctions et partagez le plaisir avec vos amis.</div></div>
      </div>
      <div class="info-notice">
        <i class="fas fa-info-circle"></i>
        <p><strong>Note :</strong> Cet outil est uniquement pour le divertissement. L'analyse « IA » est simulée — aucun traitement d'image réel n'est effectué. Vos photos ne sont jamais téléchargées ni stockées.</p>
      </div>
    </section>

  </div>
</ToolLayout>

<style>
  #tool-ai-beauty-test {
    --bt-primary: #6366f1;
    --bt-primary-light: #818cf8;
    --bt-purple: #a855f7;
    --bt-blue: #3b82f6;
    --bt-gold: #f59e0b;
    --bt-teal: #14b8a6;
    --bt-surface: #ffffff;
    --bt-surface-dim: #f8fafc;
    --bt-text: #1e293b;
    --bt-text-muted: #64748b;
    --bt-border: #e2e8f0;
    --bt-bg: linear-gradient(135deg, #eef2ff 0%, #faf5ff 50%, #fdf2f8 100%);
    --bt-card-bg: rgba(255,255,255,0.8);
    --bt-card-border: rgba(255,255,255,0.5);
    background: var(--bt-bg) !important;
    font-family: 'Roboto', system-ui, sans-serif;
    padding: clamp(12px, 3vw, 32px);
    max-width: 900px;
  }

  :global([data-theme="dark"]) #tool-ai-beauty-test {
    --bt-primary: #a5b4fc;
    --bt-primary-light: #c7d2fe;
    --bt-purple: #c084fc;
    --bt-blue: #60a5fa;
    --bt-gold: #fbbf24;
    --bt-teal: #2dd4bf;
    --bt-surface: var(--md-sys-color-surface-container-high);
    --bt-surface-dim: var(--md-sys-color-surface-container);
    --bt-text: var(--md-sys-color-on-surface);
    --bt-text-muted: var(--md-sys-color-on-surface-variant);
    --bt-border: var(--md-sys-color-outline-variant);
    --bt-bg: linear-gradient(135deg, #1e1b4b 0%, #1a0a2e 50%, #2d1036 100%);
    --bt-card-bg: rgba(30,27,75,0.6);
    --bt-card-border: rgba(99,102,241,0.2);
    background: var(--bt-bg) !important;
  }

  .hidden { display: none !important; }

  .beauty-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: center;
    margin-bottom: 24px;
    padding: 8px;
    background: var(--bt-card-bg);
    border: 1px solid var(--bt-card-border);
    border-radius: 16px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .beauty-tab {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border: none;
    border-radius: 10px;
    background: transparent;
    color: var(--bt-text-muted);
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: inherit;
  }
  .beauty-tab:hover { background: rgba(99,102,241,0.1); color: var(--bt-primary); }
  .beauty-tab.active {
    background: var(--bt-primary);
    color: #fff;
    box-shadow: 0 2px 8px rgba(99,102,241,0.35);
  }
  :global([data-theme="dark"]) .beauty-tab.active {
    background: var(--md-sys-color-primary-container);
    color: var(--md-sys-color-on-primary-container);
    box-shadow: 0 2px 8px rgba(99,102,241,0.2);
  }
  .beauty-tab i { font-size: 0.875rem; }

  .section-header {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    margin-bottom: 24px;
  }
  .section-icon {
    flex-shrink: 0;
    width: 48px; height: 48px;
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.25rem;
    background: linear-gradient(135deg, #6366f1, #818cf8);
    color: #fff;
    box-shadow: 0 4px 12px rgba(99,102,241,0.3);
  }
  .section-icon.purple { background: linear-gradient(135deg, #a855f7, #c084fc); box-shadow: 0 4px 12px rgba(168,85,247,0.3); }
  .section-icon.blue { background: linear-gradient(135deg, #3b82f6, #60a5fa); box-shadow: 0 4px 12px rgba(59,130,246,0.3); }
  .section-icon.gold { background: linear-gradient(135deg, #f59e0b, #fbbf24); box-shadow: 0 4px 12px rgba(245,158,11,0.3); color: #78350f; }
  .section-icon.teal { background: linear-gradient(135deg, #14b8a6, #2dd4bf); box-shadow: 0 4px 12px rgba(20,184,166,0.3); }

  .section-header h2 { margin: 0 0 4px; font-size: 1.5rem; font-weight: 700; color: var(--bt-text); }
  .section-header p { margin: 0; font-size: 0.9rem; color: var(--bt-text-muted); line-height: 1.5; }

  .upload-area {
    position: relative;
    border: 2px dashed var(--bt-border);
    border-radius: 16px;
    padding: 32px 20px;
    text-align: center;
    background: var(--bt-card-bg);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: border-color 0.2s, background 0.2s;
    margin-bottom: 20px;
    cursor: pointer;
  }
  .upload-area:hover, .upload-area.dragover { border-color: var(--bt-primary); background: rgba(99,102,241,0.05); }
  .upload-area.compact { padding: 20px 12px; }

  .file-input {
    position: absolute;
    width: 0;
    height: 0;
    opacity: 0;
    overflow: hidden;
  }
  .upload-label { display: flex; flex-direction: column; align-items: center; gap: 8px; pointer-events: none; }
  .upload-icon {
    width: 56px; height: 56px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.5rem;
    background: linear-gradient(135deg, #eef2ff, #e0e7ff);
    color: var(--bt-primary);
    margin-bottom: 4px;
  }
  .upload-icon.purple { background: linear-gradient(135deg, #faf5ff, #f3e8ff); color: var(--bt-purple); }
  .upload-icon.blue { background: linear-gradient(135deg, #eff6ff, #dbeafe); color: var(--bt-blue); }
  .upload-icon.gold { background: linear-gradient(135deg, #fffbeb, #fef3c7); color: var(--bt-gold); }

  :global([data-theme="dark"]) .upload-icon { background: rgba(99,102,241,0.15); }
  :global([data-theme="dark"]) .upload-icon.purple { background: rgba(168,85,247,0.15); }
  :global([data-theme="dark"]) .upload-icon.blue { background: rgba(59,130,246,0.15); }
  :global([data-theme="dark"]) .upload-icon.gold { background: rgba(245,158,11,0.15); }

  .upload-text { font-size: 0.9rem; color: var(--bt-text-muted); }
  .upload-text strong { color: var(--bt-primary); }
  .upload-hint { font-size: 0.75rem; color: var(--bt-text-muted); opacity: 0.7; }

  .preview-img {
    max-width: 100%;
    max-height: 280px;
    border-radius: 12px;
    object-fit: contain;
    margin: 0 auto;
    display: block;
    box-shadow: 0 4px 16px rgba(0,0,0,0.1);
  }
  .upload-area:has(.preview-img:not(.hidden)) .upload-label { display: none; }
  .upload-area:has(.preview-img:not(.hidden)) { border-style: solid; border-color: var(--bt-primary); padding: 12px; }

  .loader {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 32px 0;
  }
  .loader-ring {
    width: 48px; height: 48px;
    border-radius: 50%;
    border: 4px solid var(--bt-border);
    border-top-color: var(--bt-primary);
    animation: spin 0.8s linear infinite;
  }
  .loader-ring.purple { border-top-color: var(--bt-purple); }
  .loader-ring.blue { border-top-color: var(--bt-blue); }
  .loader-ring.gold { border-top-color: var(--bt-gold); }
  .loader-label { font-size: 0.9rem; font-weight: 600; color: var(--bt-primary); margin: 0; }

  @keyframes spin { to { transform: rotate(360deg); } }

  .results {
    background: var(--bt-card-bg);
    border: 1px solid var(--bt-card-border);
    border-radius: 16px;
    padding: 24px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    animation: fadeUp 0.4s ease;
  }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

