---
import ToolLayout from '../../../../layouts/ToolLayout.astro';
import type { Props as SeoProps } from '../../../../components/Seo.astro';
import { SITE_URL, DEFAULT_OG_IMAGE } from '../../../../data/site';
import body from '../../../../components/legacy/fr/tool-online-text-compare/body.html?raw';
import css from '../../../../components/legacy/fr/tool-online-text-compare/styles.css?raw';
import js from '../../../../components/legacy/fr/tool-online-text-compare/script.js?raw';

const seo: SeoProps = {
  title: 'Comparateur de texte en ligne - Vérificateur de différences',
  description: 'Comparez deux textes pour trouver les différences instantanément. Supporte plusieurs langues, le mode sombre et surligne les lignes ajoutées, supprimées et communes.',
  keywords: 'comparateur de texte, outil diff, comparer des textes, trouver des différences',
  canonical: 'https://online-tools.ni18.in/fr/tools/online-text-compare/',
  hreflang: [
    { hreflang: 'en', href: 'https://online-tools.ni18.in/tools/online-text-compare/' },
    { hreflang: 'es', href: 'https://online-tools.ni18.in/es/tools/online-text-compare/' },
    { hreflang: 'fr', href: 'https://online-tools.ni18.in/fr/tools/online-text-compare/' },
    { hreflang: 'x-default', href: 'https://online-tools.ni18.in/tools/online-text-compare/' },
  ],
  og: {
    type: 'website',
    url: 'https://online-tools.ni18.in/fr/tools/online-text-compare/',
    title: 'Comparateur de texte en ligne - Vérificateur de différences',
    description: 'Comparez deux textes pour trouver les différences instantanément. Supporte plusieurs langues, le mode sombre et surligne les lignes ajoutées, supprimées et communes.',
    image: DEFAULT_OG_IMAGE,
    locale: 'fr_FR'
  },
  twitter: {
    card: 'summary_large_image',
    url: 'https://online-tools.ni18.in/fr/tools/online-text-compare/',
    title: 'Comparateur de texte en ligne - Vérificateur de différences',
    description: 'Comparez deux textes pour trouver les différences instantanément. Supporte plusieurs langues, le mode sombre et surligne les lignes ajoutées, supprimées et communes.',
    image: DEFAULT_OG_IMAGE
  },
  jsonLd: [{
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Comparateur de texte en ligne - Vérificateur de différences',
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'All',
    url: 'https://online-tools.ni18.in/fr/tools/online-text-compare/',
    description: 'Comparez deux textes pour trouver les différences instantanément. Supporte plusieurs langues, le mode sombre et surligne les lignes ajoutées, supprimées et communes.',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' }
  }],
};
const headRaw = "<script src=\"https://cdnjs.cloudflare.com/ajax/libs/jsdiff/5.1.0/diff.min.js\" defer></script>";
---
<ToolLayout seo={seo} lang="fr" altLinks={{ en: 'https://online-tools.ni18.in/tools/online-text-compare/', es: 'https://online-tools.ni18.in/es/tools/online-text-compare/' }} headRaw={headRaw} adMinHeight={120}>
  <div class="tool-island" id="tool-online-text-compare" set:html={body} />
</ToolLayout>
<style is:global set:html={css}></style>
<script is:inline set:html={js}></script>
