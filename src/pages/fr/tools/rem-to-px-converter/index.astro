---
import ToolLayout from '../../../../layouts/ToolLayout.astro';
import { getTool, toolSeo } from '../../../../data/tools';
import { SITE_URL } from '../../../../data/site';

const tool = getTool('rem-to-px-converter')!;
const seo = toolSeo(tool, {
  title: 'Convertisseur REM en PX – Outil en Ligne Gratuit',
  description:
    'Un outil en ligne simple et gratuit pour convertir les unités REM en valeurs de pixels (px) avec une taille de police de base personnalisable, adapté aux concepteurs et développeurs.',
  keywords: 'rem en px, rem en pixels, convertisseur, css, developpement web, design responsif, accessibilite',
  author: 'ni18-in',
  ogDescription: 'Un outil en ligne simple et gratuit pour convertir sans effort des unités REM en valeurs en pixels (px).',
  ogImageAlt: 'Aperçu de l\'interface du convertisseur REM en PX.',
  appSchema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Convertisseur REM en PX',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    url: `${SITE_URL}/fr/tools/rem-to-px-converter/`,
    description: 'Un outil en ligne simple et gratuit pour convertir les unités REM en pixels.',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  },
});
seo.canonical = `${SITE_URL}/fr/tools/rem-to-px-converter/`;
if (seo.og) {
  seo.og.url = seo.canonical;
  seo.og.locale = 'fr_FR';
}
if (seo.twitter) {
  seo.twitter.url = seo.canonical;
}
const altLinks = {
  en: `${SITE_URL}/tools/rem-to-px-converter/`,
  es: `${SITE_URL}/es/tools/rem-to-px-converter/`,
};
---
<ToolLayout seo={seo} lang="fr" altLinks={altLinks} adMinHeight={120}>
  <div class="tool-island" id="tool-rem-to-px-converter">
    <header class="tool-header">
      <h1>Convertisseur REM en PX</h1>
      <p class="subtitle">Un outil de développement avec Material Design</p>
    </header>

    <section id="converter" aria-labelledby="converter-heading">
      <h2 id="converter-heading" class="sr-only">Outil de Conversion</h2>
      <div class="card">
        <form id="converter-form" aria-label="Formulaire de conversion de REM en pixels">
          <div class="form-group">
            <label for="rem-input">Valeur REM</label>
            <input type="number" id="rem-input" placeholder="ex. 1.5" required aria-required="true" value="1" step="0.05" aria-describedby="rem-input-description" />
            <p id="rem-input-description" class="sr-only">Entrez la valeur REM que vous souhaitez convertir.</p>
          </div>
          <div class="form-group">
            <label for="base-font-size">Taille de police de base (px)</label>
            <select id="base-font-size" aria-describedby="base-font-description">
              <option value="10">10px</option>
              <option value="12">12px</option>
              <option value="14">14px</option>
              <option value="16" selected>16px (Browser Default)</option>
              <option value="18">18px</option>
              <option value="20">20px</option>
              <option value="24">24px</option>
            </select>
            <p id="base-font-description" class="sr-only">Sélectionnez la taille de police de base pour le calcul de conversion. La valeur par défaut est de 16 pixels.</p>
          </div>
        </form>
        <div id="result-container" aria-live="polite">
          Valeur de pixel équivalente
          <span id="result-value">16px</span>
        </div>
      </div>
    </section>

    <section id="conversion-table" aria-labelledby="table-heading">
      <h2 id="table-heading">Conversions REM en PX courantes</h2>
      <p class="table-subtitle">Basé sur une taille de police de base de <strong>16px</strong>.</p>
      <div class="card table-container">
        <table>
          <thead>
            <tr>
              <th scope="col">REM</th>
              <th scope="col">Pixel (px)</th>
            </tr>
          </thead>
          <tbody id="conversion-table-body"></tbody>
        </table>
      </div>
    </section>
  </div>
</ToolLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const remInput = document.getElementById('rem-input');
    const baseFontSizeSelect = document.getElementById('base-font-size');
    const resultValue = document.getElementById('result-value');
    const tableBody = document.getElementById('conversion-table-body');

    function convertRemToPx() {
      const remValue = parseFloat(remInput.value);
      const baseSize = parseFloat(baseFontSizeSelect.value);
      if (isNaN(remValue) || isNaN(baseSize) || baseSize <= 0) {
        resultValue.textContent = '...';
        return;
      }
      const pxValue = remValue * baseSize;
      const formattedPx = parseFloat(pxValue.toFixed(4));
      resultValue.textContent = `${formattedPx}px`;
    }

    function populateConversionTable() {
      const baseForTable = 16;
      const commonRemValues = [0.125, 0.25, 0.5, 0.75, 1, 1.25, 1.5, 2, 2.5, 3, 4, 5, 6];
      let tableHTML = '';
      commonRemValues.forEach((rem) => {
        const px = rem * baseForTable;
        tableHTML += `<tr><td>${rem}rem</td><td>${px}px</td></tr>`;
      });
      tableBody.innerHTML = tableHTML;
    }

    remInput.addEventListener('input', convertRemToPx);
    baseFontSizeSelect.addEventListener('change', convertRemToPx);
    populateConversionTable();
    convertRemToPx();
  });
</script>

<style>
  /* rem-to-px styles, scoped by Astro to this page. Tool's --md-* custom props are remapped
     to MD3 tokens so the tool is theme-aware (dark mode) and color-consistent with the shell. */
  .tool-island {
    --md-primary-color: var(--md-sys-color-primary);
    --md-primary-dark-color: var(--md-sys-color-primary);
    --md-background-color: var(--md-sys-color-surface-container);
    --md-surface-color: var(--md-sys-color-surface-container-lowest);
    --md-text-primary-color: var(--md-sys-color-on-surface);
    --md-text-secondary-color: var(--md-sys-color-on-surface-variant);
    --md-border-color: var(--md-sys-color-outline-variant);
    --md-focus-ring-color: color-mix(in srgb, var(--md-sys-color-primary) 30%, transparent);
    font-family: 'Roboto', sans-serif;
    line-height: 1.6;
    max-width: 720px;
    margin: 0 auto;
  }
  .tool-island *, .tool-island *::before, .tool-island *::after { box-sizing: border-box; }

  .tool-header { text-align: center; padding-bottom: 1.5rem; margin-bottom: 1rem; }
  .tool-header h1 { font-size: 2.25rem; font-weight: 500; color: var(--md-primary-color); margin: 0 0 0.5rem; }
  .subtitle { color: var(--md-text-secondary-color); margin: 0; }

  h2 { font-weight: 500; font-size: 1.5rem; color: var(--md-text-primary-color); margin: 3rem 0 1.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--md-border-color); }
  .table-subtitle { font-size: 0.9rem; color: var(--md-text-secondary-color); margin-top: -1rem; margin-bottom: 1.5rem; }

  .card {
    background-color: var(--md-surface-color);
    border: 1px solid var(--md-border-color);
    border-radius: 12px;
    padding: 2rem;
    box-shadow: var(--md-sys-elevation-1);
    margin-bottom: 2rem;
  }

  .form-group { position: relative; margin-bottom: 2rem; }
  label { font-size: 0.85rem; font-weight: 500; color: var(--md-primary-color); position: absolute; top: 6px; left: 12px; z-index: 1; }
  input[type='number'], select {
    width: 100%; padding: 1.5rem 0.75rem 0.5rem; border: none;
    border-bottom: 1px solid var(--md-text-secondary-color);
    background-color: var(--md-background-color); color: var(--md-text-primary-color); font-size: 1.1rem;
    border-radius: 8px 8px 0 0;
    transition: border-bottom-color 0.2s, background-color 0.2s;
  }
  input[type='number']:focus, select:focus {
    outline: none;
    border-bottom: 2px solid var(--md-primary-color);
    background-color: color-mix(in srgb, var(--md-primary-color) 8%, var(--md-background-color));
  }
  select option { color: initial; background-color: var(--md-surface-color); }

  #result-container {
    margin-top: 2rem; padding: 1.5rem; background-color: var(--md-background-color);
    border-radius: 12px; text-align: center; font-size: 1.25rem; color: var(--md-text-secondary-color);
  }
  #result-value { display: block; font-size: 2.5rem; font-weight: 500; color: var(--md-primary-color); margin-top: 0.5rem; }

  .table-container { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; margin-top: 1rem; }
  th, td { padding: 0.75rem 1rem; text-align: left; border-bottom: 1px solid var(--md-border-color); }
  thead th { background-color: var(--md-background-color); font-weight: 500; color: var(--md-text-secondary-color); }
  tbody tr:hover { background-color: color-mix(in srgb, var(--md-primary-color) 4%, transparent); }

  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border-width: 0;
  }
</style>
