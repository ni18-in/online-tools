---
import ToolLayout from '../../../../layouts/ToolLayout.astro';
import { getTool, toolSeo } from '../../../../data/tools';
import { SITE_URL } from '../../../../data/site';

const tool = getTool('rem-to-px-converter')!;
const seo = toolSeo(tool, {
  title: 'Convertisseur REM en PX – Outil en Ligne Gratuit',
  description:
    'Un outil en ligne simple et gratuit pour convertir les unités REM en valeurs de pixels (px) avec une taille de police de base personnalisable, adapté aux concepteurs et développeurs.',
  keywords: 'rem en px, rem en pixels, convertisseur, css, developpement web, design responsif, accessibilite',
  author: 'ni18-in',
  ogDescription: 'Un outil en ligne simple et gratuit pour convertir sans effort des unités REM en valeurs en pixels (px).',
  ogImageAlt: 'Aperçu de l\'interface du convertisseur REM en PX.',
  appSchema: {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Convertisseur REM en PX',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    url: `${SITE_URL}/fr/tools/rem-to-px-converter/`,
    description: 'Un outil en ligne simple et gratuit pour convertir les unités REM en pixels.',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  },
});
seo.canonical = `${SITE_URL}/fr/tools/rem-to-px-converter/`;
if (seo.og) {
  seo.og.url = seo.canonical;
  seo.og.locale = 'fr_FR';
}
if (seo.twitter) {
  seo.twitter.url = seo.canonical;
}
const altLinks = {
  en: `${SITE_URL}/tools/rem-to-px-converter/`,
  es: `${SITE_URL}/es/tools/rem-to-px-converter/`,
};
---
<ToolLayout seo={seo} lang="fr" altLinks={altLinks} adMinHeight={120}>
  <div class="tool-island legacy-tw" id="tool-rem-to-px-converter">
    <div class="container mx-auto max-w-3xl px-4 py-8 sm:py-12">
      <header class="text-center mb-10">
        <h1 class="text-4xl sm:text-5xl font-bold text-indigo-600 tracking-tight">Convertisseur REM en PX</h1>
        <p class="mt-3 text-lg text-slate-600">Convertissez instantanément des unités REM en pixels.</p>
      </header>

      <main>
        <section id="converter" aria-labelledby="converter-heading">
          <h2 id="converter-heading" class="sr-only">Outil de Conversion</h2>
          <div class="bg-white rounded-xl shadow-lg p-6 sm:p-8 mb-10">
            <form id="converter-form" aria-label="Formulaire de conversion de REM en pixels" class="space-y-6">
              <div>
                <label for="rem-input" class="block text-sm font-medium text-slate-700">Valeur REM</label>
                <div class="mt-1 relative rounded-md shadow-sm">
                  <input type="number" id="rem-input" placeholder="ex. 1.5" required aria-required="true" value="1" step="0.05" class="block w-full px-4 py-3 border-slate-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500 text-lg" aria-describedby="rem-input-description" />
                  <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                    <span class="text-slate-500 sm:text-sm">rem</span>
                  </div>
                </div>
                <p id="rem-input-description" class="sr-only">Entrez la valeur REM que vous souhaitez convertir.</p>
              </div>
              <div>
                <label for="base-font-size" class="block text-sm font-medium text-slate-700">Taille de police de base (px)</label>
                <select id="base-font-size" class="mt-1 block w-full pl-3 pr-10 py-3 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md" aria-describedby="base-font-description">
                  <option value="10">10px</option>
                  <option value="12">12px</option>
                  <option value="14">14px</option>
                  <option value="16" selected>16px (Par défaut du navigateur)</option>
                  <option value="18">18px</option>
                  <option value="20">20px</option>
                  <option value="24">24px</option>
                </select>
                <p id="base-font-description" class="sr-only">Sélectionnez la taille de police de base pour le calcul de conversion. La valeur par défaut est de 16 pixels.</p>
              </div>
            </form>
            <div id="result-container" aria-live="polite" class="mt-8 text-center bg-indigo-50 border border-indigo-200 rounded-lg p-6">
              <p class="text-lg font-medium text-indigo-800">Valeur de pixel équivalente</p>
              <p id="result-value" class="text-5xl font-bold text-indigo-600 tracking-tight mt-2">16px</p>
            </div>
          </div>
        </section>

        <section id="conversion-table" aria-labelledby="table-heading" class="bg-white rounded-xl shadow-lg p-6 sm:p-8">
          <h2 id="table-heading" class="text-2xl font-semibold text-slate-800 mb-4">Conversions REM en PX courantes</h2>
          <p class="text-sm text-slate-500 mb-6">Basé sur une taille de police de base de <strong class="font-medium text-slate-700">16px</strong>.</p>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200">
              <thead class="bg-slate-50">
                <tr>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">REM</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Pixel (px)</th>
                </tr>
              </thead>
              <tbody id="conversion-table-body" class="bg-white divide-y divide-slate-200"></tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </div>
</ToolLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const remInput = document.getElementById('rem-input');
    const baseFontSizeSelect = document.getElementById('base-font-size');
    const resultValue = document.getElementById('result-value');
    const tableBody = document.getElementById('conversion-table-body');

    function convertRemToPx() {
      const remValue = parseFloat(remInput.value);
      const baseSize = parseFloat(baseFontSizeSelect.value);
      if (isNaN(remValue) || isNaN(baseSize) || baseSize <= 0) {
        resultValue.textContent = '...';
        return;
      }
      const pxValue = remValue * baseSize;
      const formattedPx = parseFloat(pxValue.toFixed(4));
      resultValue.textContent = `${formattedPx}px`;
    }

    function populateConversionTable() {
      const baseForTable = 16;
      const commonRemValues = [0.125, 0.25, 0.5, 0.75, 1, 1.25, 1.5, 2, 2.5, 3, 4, 5, 6];
      let tableHTML = '';
      commonRemValues.forEach((rem) => {
        const px = rem * baseForTable;
        tableHTML += `<tr class="hover:bg-slate-50"><td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-900">${rem}rem</td><td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">${px}px</td></tr>`;
      });
      tableBody.innerHTML = tableHTML;
    }

    remInput.addEventListener('input', convertRemToPx);
    baseFontSizeSelect.addEventListener('change', convertRemToPx);
    populateConversionTable();
    convertRemToPx();
  });
</script>
