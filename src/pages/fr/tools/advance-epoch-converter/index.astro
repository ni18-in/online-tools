---
import ToolLayout from '../../../../layouts/ToolLayout.astro';
import type { Props as SeoProps } from '../../../../components/Seo.astro';
import { SITE_URL, DEFAULT_OG_IMAGE } from '../../../../data/site';
import body from '../../../../components/legacy/fr/tool-advance-epoch-converter/body.html?raw';
import css from '../../../../components/legacy/fr/tool-advance-epoch-converter/styles.css?raw';
import js from '../../../../components/legacy/fr/tool-advance-epoch-converter/script.js?raw';

const seo: SeoProps = {
