---
import ToolLayout from '../../../../layouts/ToolLayout.astro';
import type { Props as SeoProps } from '../../../../components/Seo.astro';
import { SITE_URL, DEFAULT_OG_IMAGE } from '../../../../data/site';
import body from '../../../../components/legacy/fr/tool-vtf-converter/body.html?raw';
import css from '../../../../components/legacy/fr/tool-vtf-converter/styles.css?raw';
import js from '../../../../components/legacy/fr/tool-vtf-converter/script.js?raw';

const seo: SeoProps = {
  title: 'Convertisseur VTF - Outil de conversion d\'image en VTF',
  description: 'Convertissez vos images (PNG, JPG) au format VTF (Valve Texture Format) gratuitement dans votre navigateur. Sécurisé, rapide et côté client.',
  keywords: 'convertisseur vtf, image en vtf, valve texture format, textures source',
  canonical: 'https://online-tools.ni18.in/fr/tools/vtf-converter/',
  hreflang: [
    { hreflang: 'en', href: 'https://online-tools.ni18.in/tools/vtf-converter/' },
    { hreflang: 'es', href: 'https://online-tools.ni18.in/es/tools/vtf-converter/' },
    { hreflang: 'fr', href: 'https://online-tools.ni18.in/fr/tools/vtf-converter/' },
    { hreflang: 'x-default', href: 'https://online-tools.ni18.in/tools/vtf-converter/' },
  ],
  og: {
    type: 'website',
    url: 'https://online-tools.ni18.in/fr/tools/vtf-converter/',
    title: 'Convertisseur VTF - Outil de conversion d\'image en VTF',
    description: 'Convertissez vos images (PNG, JPG) au format VTF (Valve Texture Format) gratuitement dans votre navigateur. Sécurisé, rapide et côté client.',
    image: DEFAULT_OG_IMAGE,
    locale: 'fr_FR'
  },
  twitter: {
    card: 'summary_large_image',
    url: 'https://online-tools.ni18.in/fr/tools/vtf-converter/',
    title: 'Convertisseur VTF - Outil de conversion d\'image en VTF',
    description: 'Convertissez vos images (PNG, JPG) au format VTF (Valve Texture Format) gratuitement dans votre navigateur. Sécurisé, rapide et côté client.',
    image: DEFAULT_OG_IMAGE
  },
  jsonLd: [{
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Convertisseur VTF - Outil de conversion d\'image en VTF',
    applicationCategory: 'MultimediaApplication',
    operatingSystem: 'All',
    url: 'https://online-tools.ni18.in/fr/tools/vtf-converter/',
    description: 'Convertissez vos images (PNG, JPG) au format VTF (Valve Texture Format) gratuitement dans votre navigateur. Sécurisé, rapide et côté client.',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' }
  }],
};

---
<ToolLayout seo={seo} lang="fr" altLinks={{ en: 'https://online-tools.ni18.in/tools/vtf-converter/', es: 'https://online-tools.ni18.in/es/tools/vtf-converter/' }} adMinHeight={120}>
  <div class="tool-island legacy-tw" id="tool-vtf-converter" set:html={body} />
</ToolLayout>
<style is:global set:html={css}></style>
<script is:inline set:html={js}></script>
