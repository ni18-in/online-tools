---
// Pre-paint theme resolver. Runs synchronously in <head> BEFORE first paint so the MD3
// shell never flashes the wrong color scheme (CLS/FOUC mitigation). Sets data-theme on
// <html>; md3-tokens.css keys both schemes off it. Tool islands keep their own dark logic.
---
<script is:inline>
  (function () {
    try {
      var stored = localStorage.getItem('theme');
      var theme = stored || (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.dataset.theme = theme;
    } catch (e) {
      document.documentElement.dataset.theme = 'light';
    }
  })();
</script>
