---
// Google Analytics 4. `is:inline` keeps Astro from bundling/deferring the gtag snippet
// so it behaves exactly like the hand-pasted version it replaces.
import { GA_ID } from '../data/site';
---
<script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
<script is:inline define:vars={{ GA_ID }}>
  window.dataLayer = window.dataLayer || [];
  function gtag() { dataLayer.push(arguments); }
  gtag('js', new Date());
  gtag('config', GA_ID);
</script>
