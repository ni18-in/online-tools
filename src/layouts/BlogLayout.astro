---
/**
 * BlogLayout.astro — wraps a preserved blog-post article in the MD3 shell with a readable
 * column. Like ToolLayout, the legacy article HTML is injected verbatim via set:html.
 */
import BaseLayout from './BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import type { Props as SeoProps } from '../components/Seo.astro';
import { type Locale } from '../data/i18n';

export interface Props {
  seo: SeoProps;
  lang?: Locale;
  altLinks?: Partial<Record<Locale, string>>;
  bodyHtml: string;
  headRaw?: string;
  ad?: boolean;
}
const { seo, lang = 'en', altLinks = {}, bodyHtml, headRaw, ad = true } = Astro.props;
---
<BaseLayout seo={seo} lang={lang} current="blogs" altLinks={altLinks} headRaw={headRaw} adsEnabled={ad}>
  <main id="main-content" class="blog-main">
    {ad && <AdSlot placement="in-content" minHeight={250} class="blog-ad" />}
    <article class="blog-article" set:html={bodyHtml} />
  </main>
</BaseLayout>

<style>
  .blog-main {
    max-width: 768px;
    margin: 0 auto;
    padding: 32px 16px;
  }
  .blog-ad { margin: 0 auto 24px; }
  .blog-article :global(img) { max-width: 100%; height: auto; border-radius: 12px; }
  .blog-article :global(h1) { font-size: 2rem; line-height: 1.2; }
  .blog-article :global(h2) { font-size: 1.5rem; margin-top: 2rem; }
  .blog-article :global(p) { line-height: 1.7; }
  .blog-article :global(a) { color: var(--md-sys-color-primary); }
</style>
