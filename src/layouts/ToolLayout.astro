---
/**
 * ToolLayout.astro — wraps a PRESERVED legacy tool island in the MD3 shell.
 *
 * The tool's exact markup + inline <style> + inline <script> are injected verbatim via
 * set:html (Astro never parses/bundles set:html, so getElementById / onclick / classList all
 * survive). External tool assets (script.js) are re-attached with is:inline. Tools that
 * originally loaded the Tailwind CDN set usesTailwind → wrapped in .legacy-tw to receive the
 * SCOPED Preflight. CDN libs go in headRaw (verbatim, exact load order).
 */
import BaseLayout from './BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import type { Props as SeoProps } from '../components/Seo.astro';
import { type Locale } from '../data/i18n';
import '../styles/tw-preflight-scoped.css';

export interface Props {
  seo: SeoProps;
  lang?: Locale;
  altLinks?: Partial<Record<Locale, string>>;
  /** Verbatim tool markup + inline <style>/<script>. */
  bodyHtml: string;
  /** Tool originally used the Tailwind CDN → apply scoped Preflight. */
  usesTailwind?: boolean;
  /** Verbatim CDN <link>/<script> deps for <head> (exact load order). */
  headRaw?: string;
  /** External tool scripts (e.g. /tools/<slug>/script.js), attached after the island. */
  scriptSrcs?: string[];
  /** In-content ad above the tool (reserved height → no CLS). */
  ad?: boolean;
  adMinHeight?: number;
}
const {
  seo,
  lang = 'en',
  altLinks = {},
  bodyHtml,
  usesTailwind = false,
  headRaw,
  scriptSrcs = [],
  ad = true,
  adMinHeight = 280,
} = Astro.props;
---
<BaseLayout
  seo={seo}
  lang={lang}
  current="tools"
  altLinks={altLinks}
  headRaw={headRaw}
  adsEnabled={ad}
>
  <main id="main-content" class="tool-main">
    {ad && <AdSlot placement="in-content" minHeight={adMinHeight} class="tool-ad" />}
    <div class:list={['tool-island', { 'legacy-tw': usesTailwind }]} set:html={bodyHtml} />
    {scriptSrcs.map((src) => <script is:inline src={src}></script>)}
  </main>
</BaseLayout>

<style>
  .tool-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px;
  }
  .tool-ad { margin: 0 auto 24px; }
</style>
