---
/**
 * ToolLayout.astro — MD3 shell around a preserved tool.
 *
 * The tool's markup goes in the page's <slot> wrapped in `.tool-island` (Tailwind tools add
 * `.legacy-tw` for the scoped Preflight). The page keeps the tool's CSS in an Astro scoped
 * <style> (auto-isolated → cannot leak into the shell or other tools) and its JS in an
 * is:inline <script> (verbatim, untouched). CDN libs/fonts a tool needs go in `headRaw`;
 * external tool scripts (script.js) in `scriptSrcs`.
 */
import BaseLayout from './BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import type { Props as SeoProps } from '../components/Seo.astro';
import { type Locale } from '../data/i18n';
import '../styles/tw-preflight-scoped.css';

export interface Props {
  seo: SeoProps;
  lang?: Locale;
  altLinks?: Partial<Record<Locale, string>>;
  headRaw?: string;
  scriptSrcs?: string[];
  ad?: boolean;
  adMinHeight?: number;
}
const {
  seo,
  lang = 'en',
  altLinks = {},
  headRaw,
  scriptSrcs = [],
  ad = true,
  adMinHeight = 280,
} = Astro.props;
---
<BaseLayout seo={seo} lang={lang} current="tools" altLinks={altLinks} headRaw={headRaw} adsEnabled={ad}>
  <main id="main-content" class="tool-main">
    <slot />
    {scriptSrcs.map((src) => <script is:inline src={src}></script>)}
    {ad && <AdSlot placement="below-content" minHeight={adMinHeight} class="tool-ad" />}
  </main>
</BaseLayout>

<style>
  /* width:100% defeats the flex shrink-wrap (a column flex item with auto cross-margins
     collapses to content width) so every tool gets the full page width to lay out in. */
  .tool-main {
    width: 100%;
    padding: 24px 16px 8px;
  }
  .tool-ad { margin: 28px auto 0; max-width: 728px; }
  /* One consistent MD3 work-surface for EVERY tool: centered, capped width, themed card.
     The extractor strips each tool's own page background, so this is the single canvas.
     A few intentionally-themed islands (dark basic-auth, gradient AI tools) override the bg
     in their own page via utility classes. */
  :global(.tool-island) {
    max-width: 1080px;
    margin: 0 auto;
    /* Soft neutral canvas — tools with their own dark/branded bg override via #tool-<slug>;
       tools without one get this. No border/shadow so it never double-frames a tool's own cards. */
    background: var(--md-sys-color-surface-container);
    color: var(--md-sys-color-on-surface);
    border-radius: var(--md-sys-shape-corner-extra-large);
    padding: clamp(12px, 2vw, 28px);
  }
</style>
