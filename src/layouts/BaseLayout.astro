---
/**
 * BaseLayout.astro — the document shell every page uses.
 * Head: charset/viewport, favicons + manifest, theme-color, Roboto (MD3), the design-token
 * + Tailwind stylesheets, ThemeNoFlash (pre-paint), Analytics (GA4), <Seo>, an optional
 * verbatim head escape-hatch (`headRaw`, for a tool's exact CDN deps), and the AdSense loader
 * when ads are enabled. Body: sticky header + <slot/> + footer. MWC is a deferred module.
 */
import Seo, { type Props as SeoProps } from '../components/Seo.astro';
import Analytics from '../components/Analytics.astro';
import ThemeNoFlash from '../components/ThemeNoFlash.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { type Locale } from '../data/i18n';
import { ADSENSE_CLIENT } from '../data/site';
import '../styles/md3-tokens.css';
import '../styles/tailwind.css';

export interface Props {
  seo: SeoProps;
  lang?: Locale;
  current?: 'home' | 'tools' | 'blogs' | 'about';
  altLinks?: Partial<Record<Locale, string>>;
  /** Verbatim HTML injected into <head> (a tool's exact CDN <link>/<script> deps). */
  headRaw?: string;
  /** Load the AdSense library (pages that render <AdSlot>). */
  adsEnabled?: boolean;
  bodyClass?: string;
}

const {
  seo,
  lang = 'en',
  current,
  altLinks = {},
  headRaw,
  adsEnabled = false,
  bodyClass,
} = Astro.props;
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#4f46e5" />

    <link rel="apple-touch-icon" sizes="180x180" href="/assets/icons/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/icons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/icons/favicon-16x16.png" />
    <link rel="manifest" href="/assets/icons/site.webmanifest" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <ThemeNoFlash />
    <Analytics />
    <Seo {...seo} />

    {adsEnabled && (
      <>
        <link rel="preconnect" href="https://pagead2.googlesyndication.com" />
        <link rel="dns-prefetch" href="https://pagead2.googlesyndication.com" />
        <link rel="preconnect" href="https://googleads.g.doubleclick.net" />
        <link rel="dns-prefetch" href="https://googleads.g.doubleclick.net" />
        <link rel="preconnect" href="https://adservice.google.com" />
        <link rel="dns-prefetch" href="https://adservice.google.com" />
      </>
    )}

    {adsEnabled && import.meta.env.PROD && (
      <script
        is:inline
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CLIENT}`}
        crossorigin="anonymous"></script>
    )}

    {headRaw && <Fragment set:html={headRaw} />}
  </head>
  <body class={bodyClass}>
    <div class="site-shell">
      <SiteHeader lang={lang} current={current} altLinks={altLinks} />
      <slot />
      <SiteFooter lang={lang} />
    </div>

    <div id="global-snackbar" class="md3-snackbar" role="status" aria-live="polite">
      <span id="global-snackbar-text" class="md3-snackbar__text"></span>
      <button id="global-snackbar-action" class="md3-snackbar__action" style="display: none;"></button>
    </div>

    <script is:inline>
      window.showToast = function(message, duration = 4000, actionText = '', actionCallback = null) {
        const snackbar = document.getElementById('global-snackbar');
        const textEl = document.getElementById('global-snackbar-text');
        const actionBtn = document.getElementById('global-snackbar-action');
        
        if (!snackbar || !textEl) return;
        
        textEl.textContent = message;
        
        if (actionText && actionCallback) {
          actionBtn.textContent = actionText;
          actionBtn.style.display = 'inline-block';
          actionBtn.onclick = () => {
            actionCallback();
            snackbar.classList.remove('md3-snackbar--active');
          };
        } else {
          actionBtn.style.display = 'none';
          actionBtn.onclick = null;
        }
        
        snackbar.classList.add('md3-snackbar--active');
        
        if (window.snackbarTimer) {
          clearTimeout(window.snackbarTimer);
        }
        
        window.snackbarTimer = setTimeout(() => {
          snackbar.classList.remove('md3-snackbar--active');
        }, duration);
      };

      // Intercept legacy window.alert calls
      window.alert = function(message) {
        window.showToast(message);
        console.log("Alert intercepted:", message);
      };
    </script>

    <style is:global>
      .md3-snackbar {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%) translateY(100px);
        background-color: var(--md-sys-color-inverse-surface, #313033);
        color: var(--md-sys-color-inverse-on-surface, #f4f0f4);
        padding: 14px 16px;
        border-radius: 8px;
        box-shadow: 0px 3px 5px -1px rgba(0,0,0,0.2), 0px 6px 10px 0px rgba(0,0,0,0.14), 0px 1px 18px 0px rgba(0,0,0,0.12);
        display: flex;
        align-items: center;
        gap: 8px;
        min-width: 288px;
        max-width: 568px;
        z-index: 9999;
        transition: transform 0.25s cubic-bezier(0, 0, 0.2, 1), opacity 0.25s ease;
        opacity: 0;
        pointer-events: none;
      }

      .md3-snackbar--active {
        transform: translateX(-50%) translateY(0);
        opacity: 1;
        pointer-events: auto;
      }

      .md3-snackbar__text {
        flex-grow: 1;
        font-size: 0.875rem;
        line-height: 1.43;
        letter-spacing: 0.01786em;
      }

      .md3-snackbar__action {
        background: none;
        border: none;
        color: var(--md-sys-color-inverse-primary, #d0bcff);
        font-weight: 500;
        font-size: 0.875rem;
        cursor: pointer;
        padding: 0 8px;
        text-transform: uppercase;
      }
    </style>

    <!-- Material Web Components: deferred module, never blocks first paint. -->
    <script>
      import '../scripts/md3.ts';
    </script>
  </body>
</html>
